; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="welcome traveller"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/event_bus.gd"
DebugService="*res://autoload/debug_service.gd"
DisplayManager="*res://autoload/display_manager.gd"
GameModeManager="*res://autoload/game_mode_manager.gd"
DayNightManager="*res://autoload/day_night_manager.gd"
ThemeService="*res://autoload/theme_service.gd"
GridService="*res://autoload/grid_service.gd"
ViewManager="*res://autoload/view_manager.gd"
FurnitureService="*res://autoload/furniture_service.gd"
NavService="*res://autoload/nav_service.gd"
EntityService="*res://autoload/entity_service.gd"
GameTimeManager="*res://autoload/game_time_manager.gd"
EconomyManager="*res://autoload/economy_manager.gd"
ReputationManager="*res://autoload/reputation_manager.gd"
CustomerService="*res://autoload/customer_service.gd"
GameClock="*res://autoload/game_clock.gd"
StaffService="*res://autoload/staff_service.gd"
KitchenService="*res://autoload/kitchen_service.gd"
TableFoodService="*res://autoload/table_food_service.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[layer_names]

2d_physics/layer_1="terrain"
2d_physics/layer_2="furniture"
2d_physics/layer_3="units"
2d_physics/layer_4="enemies"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
